      "cell_type": "code",
      "source": [
        "def recommend_knn(movie_name, n=5):\n",
        "    \"\"\"Recommend n similar movies using KNN + cosine similarity.\"\"\"\n",
        "    if movie_name not in movie_user_mat.index:\n",
        "        print(\"Movie not found in matrix. Try exact title with year.\")\n",
        "        return None\n",
        "\n",
        "    idx = movie_user_mat.index.get_loc(movie_name)\n",
        "    distances, indices = knn.kneighbors(csr[idx], n_neighbors=n+1)\n",
        "\n",
        "    print(f\"Movies similar to '{movie_name}':\\n\")\n",
        "    recs = []\n",
        "    for dist, i in zip(distances.flatten()[1:], indices.flatten()[1:]):  # skip itself\n",
        "        title = movie_user_mat.index[i]\n",
        "        recs.append((title, round(1 - dist, 3)))   # cosine similarity = 1 - distance\n",
        "    return pd.DataFrame(recs, columns=['Movie', 'Cosine_Similarity'])"
      ],
      "metadata": {
        "id": "q2as95YMp2_U"
      },
