    {
      "cell_type": "code",
      "source": [
        "# Convert Age column to integer type as it was likely parsed as object (string)\n",
        "df['Age'] = df['Age'].astype(int)\n",
        "\n",
        "# Map Age codes -> readable groups\n",
        "age_map = {1:\"Under 18\",18:\"18-24\",25:\"25-34\",35:\"35-44\",\n",
        "           45:\"45-49\",50:\"50-55\",56:\"56+\"}\n",
        "df['Age_group'] = df['Age'].map(age_map)\n",
        "\n",
        "# Convert Occupation column to integer type\n",
        "df['Occupation'] = df['Occupation'].astype(int)\n",
        "\n",
        "# Map Occupation codes -> labels\n",
        "occ_map = {0:\"other\",1:\"academic/educator\",2:\"artist\",3:\"clerical/admin\",\n",
        "           4:\"college/grad student\",5:\"customer service\",6:\"doctor/health care\",\n",
        "           7:\"executive/managerial\",8:\"farmer\",9:\"homemaker\",10:\"K-12 student\",\n",
        "           11:\"lawyer\",12:\"programmer\",13:\"retired\",14:\"sales/marketing\",\n",
        "           15:\"scientist\",16:\"self-employed\",17:\"technician/engineer\",\n",
        "           18:\"tradesman/craftsman\",19:\"unemployed\",20:\"writer\"}\n",
        "df['Occupation_label'] = df['Occupation'].map(occ_map)\n",
        "\n",
        "# Derive Release Year from Title e.g. \"Toy Story (1995)\"\n",
        "df['ReleaseYear'] = df['Title'].str.extract(r'\\((\\d{4})\\)').astype(float)\n",
        "df['Decade'] = (df['ReleaseYear']//10*10)\n",
        "\n",
        "# Convert timestamp to datetime (optional, useful feature)\n",
        "df['RatingTime'] = pd.to_datetime(df['Timestamp'], unit='s')\n",
        "\n",
        "df[['Title','ReleaseYear','Decade','Age_group','Occupation_label']].head()"
      ],
