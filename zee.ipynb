    {
      "cell_type": "markdown",
      "source": [
        "## Using MF Embeddings for Similarity\n",
        "\n",
        "After training, the model gives us latent embedding vectors for each user (`pu`) and\n",
        "each item (`qi`). We redesign our similarity functions to use these 4-dimensional\n",
        "embeddings (instead of raw rating vectors) and find similar items/users via cosine similarity."
      ],
      "metadata": {
        "id": "Bcvfqi2dqid5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "\n",
        "# Item embeddings (qi) and user embeddings (pu)\n",
        "item_factors = svd.qi   # shape: (n_items, 4)\n",
        "user_factors = svd.pu   # shape: (n_users, 4)\n",
        "\n",
        "# Maps: raw id -> inner id used by surprise\n",
        "movie_id_to_title = movies.set_index('MovieID')['Title'].to_dict()\n",
        "\n",
        "def item_embedding(movie_id):\n",
        "    inner = trainset.to_inner_iid(movie_id)\n",
        "    return item_factors[inner]\n",
        "\n",
        "def similar_items_mf(movie_id, top_n=5):\n",
        "    \"\"\"Find similar movies using MF item embeddings (d=4).\"\"\"\n",
        "    try:\n",
        "        target = item_embedding(movie_id).reshape(1, -1)\n",
        "    except ValueError:\n",
        "        print(\"Movie not in training set.\"); return None\n",
        "    sims = cosine_similarity(target, item_factors).flatten()\n",
        "\n",
        "    # Build list of (raw movie id, similarity)\n",
        "    results = []\n",
        "    for inner_id, score in enumerate(sims):\n",
        "        raw_id = trainset.to_raw_iid(inner_id)\n",
        "        results.append((movie_id_to_title.get(raw_id, raw_id), score))\n",
        "    res_df = pd.DataFrame(results, columns=['Movie','Similarity']) \\\n",
        "                .sort_values('Similarity', ascending=False)\n",
        "    return res_df.iloc[1:top_n+1]   # skip itself"
      ],
      "metadata": {
        "id": "ufLGXTeiqjRt"
      },
      "execution_count": null,
      "outputs": []
    },
