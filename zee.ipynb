      "cell_type": "code",
      "source": [
        "from scipy.sparse import csr_matrix\n",
        "from sklearn.neighbors import NearestNeighbors\n",
        "\n",
        "# movie x user matrix (rows = movies)\n",
        "movie_user_mat = movie_matrix.fillna(0).T     # Title as rows, UserID as columns\n",
        "\n",
        "# Optional: filter to popular movies for cleaner recommendations\n",
        "popular_titles = movie_stats[movie_stats['Num_Ratings'] > 50].index\n",
        "movie_user_mat = movie_user_mat.loc[movie_user_mat.index.intersection(popular_titles)]\n",
        "\n",
        "# CSR sparse matrix\n",
        "csr = csr_matrix(movie_user_mat.values)\n",
        "print(\"CSR matrix shape:\", csr.shape)\n",
        "\n",
        "# KNN model with cosine similarity\n",
        "knn = NearestNeighbors(metric='cosine', algorithm='brute', n_neighbors=6)\n",
        "knn.fit(csr)"
      ],
