        "def similar_users_mf(user_id, top_n=5):\n",
        "    \"\"\"Find similar users using MF user embeddings (d=4).\"\"\"\n",
        "    try:\n",
        "        inner = trainset.to_inner_uid(user_id)\n",
        "    except ValueError:\n",
        "        print(\"User not in training set.\"); return None\n",
        "    target = user_factors[inner].reshape(1, -1)\n",
        "    sims = cosine_similarity(target, user_factors).flatten()\n",
        "\n",
        "    results = []\n",
        "    for inner_id, score in enumerate(sims):\n",
        "        raw_id = trainset.to_raw_uid(inner_id)\n",
        "        results.append((raw_id, score))\n",
        "    res_df = pd.DataFrame(results, columns=['UserID','Similarity']) \\\n",
        "                .sort_values('Similarity', ascending=False)\n",
        "    return res_df.iloc[1:top_n+1]\n",
        "\n",
        "print(\"Users most similar to User 1 (using MF embeddings):\")\n",
        "similar_users_mf(1, top_n=5)"
