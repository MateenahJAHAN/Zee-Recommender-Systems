        "}\n",
        "\n",
        "# Sirf wahi rakhein jo dataset mein exist karte hain\n",
        "new_user_ratings = {k:v for k,v in new_user_ratings.items() if k in movie_matrix.columns}\n",
        "print(\"New user rated movies:\", list(new_user_ratings.keys()))"
      ],
      "metadata": {
