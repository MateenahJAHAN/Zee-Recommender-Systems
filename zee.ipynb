    {
      "cell_type": "code",
      "source": [
        "def recommend_pearson(movie_name, min_ratings=100, top_n=5):\n",
        "    \"\"\"Item-based recommender using Pearson correlation.\"\"\"\n",
        "    if movie_name not in movie_matrix.columns:\n",
        "        print(\"Movie not found. Check exact title (with year), e.g. 'Liar Liar (1997)'\")\n",
        "        return None\n",
        "\n",
        "    target_ratings = movie_matrix[movie_name]\n",
        "\n",
        "    # Correlation of target movie with all other movies\n",
        "    similar = movie_matrix.corrwith(target_ratings)\n",
        "    corr_df = pd.DataFrame(similar, columns=['Correlation']).dropna()\n",
        "\n",
        "    # Add number of ratings to filter out unreliable ones\n",
        "    corr_df = corr_df.join(movie_stats['Num_Ratings'])\n",
        "\n",
        "    # Keep only movies with enough ratings, sort by correlation\n",
        "    result = corr_df[corr_df['Num_Ratings'] > min_ratings] \\\n",
        "                .sort_values('Correlation', ascending=False)\n",
        "\n",
        "    # Drop the movie itself (top row) and return next top_n\n",
        "    return result.drop(index=movie_name, errors='ignore').head(top_n)"
      ],
      "metadata": {
        "id": "mqjK29lypa7O"
      },
