        "# In top 10 users ki saari ratings nikaalein\n",
        "recs = df[df['UserID'].isin(top10.index)][['UserID','Title','Rating']].copy()\n",
        "\n",
        "# Similarity index add karein\n",
        "recs['Similarity'] = recs['UserID'].map(top10)\n",
        "\n",
        "# Weighted rating = Rating * Similarity\n",
        "recs['Weighted'] = recs['Rating'] * recs['Similarity']\n",
        "\n",
        "# Movies jo new user ne already dekhi unhe hata dein\n",
        "recs = recs[~recs['Title'].isin(rated_movies)]\n",
        "\n",
        "# Recommendation score = sum(weighted) / sum(similarity)\n",
        "agg = recs.groupby('Title').apply(\n",
        "    lambda x: x['Weighted'].sum() / x['Similarity'].sum()\n",
        ").sort_values(ascending=False)\n",
        "\n",
        "print(\"Top 10 recommended movies for the new user:\\n\")\n",
        "agg.head(10)"
      ],
